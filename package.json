{
    "name": "uptime-checker-worker",
    "version": "1.0.0",
    "description": "Uptime monitoring worker with in-memory scheduler and protocol checkers",
    "main": "dist/main.js",
    "scripts": {
        "dev": "tsx watch src/main.ts",
        "build": "tsc -p tsconfig.build.json",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "lint": "biome lint .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "format:check": "biome format --check .",
        "start": "node dist/main.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "ci": "pnpm run typecheck && pnpm run lint && pnpm run test:coverage",
        "health": "node scripts/healthcheck.js"
    },
    "dependencies": {
        "amqplib": "^0.10.9",
        "dotenv": "^17.2.3",
        "pino": "^9.5.0",
        "pino-pretty": "^13.1.3",
        "uuid": "^11.0.3",
        "zod": "^4.2.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.9",
        "@types/amqplib": "^0.10.6",
        "@types/node": "24.12.0",
        "@types/uuid": "^10.0.0",
        "@vitest/coverage-v8": "4.1.2",
        "tsx": "4.21.0",
        "typescript": "^5.7.3",
        "vitest": "4.1.2"
    }
}